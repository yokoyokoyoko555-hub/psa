generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ===== ENUMS =====

enum UserRole {
  ADMIN
  STAFF
  ACCOUNTING
  CUSTOMER
}

enum CardStatus {
  DRAFT
  SUBMITTED_BY_CUSTOMER
  RECEIVED_BY_STORE
  INSPECTION_PENDING
  INSPECTED
  READY_FOR_PSA
  SUBMITTED_TO_PSA
  PSA_RECEIVED
  GRADING
  GRADE_AVAILABLE
  RETURNED_TO_STORE
  READY_FOR_CUSTOMER_RETURN
  RETURNED_TO_CUSTOMER
  UPCHARGE_UNPAID
  UPCHARGE_PAID
  PROBLEM
  CANCELLED
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ServiceLevel {
  VALUE // 旧プラン（未使用・互換のため残置）
  VALUE_BULK
  VALUE_PLUS
  VALUE_MAX
  REGULAR
  EXPRESS
  SUPER_EXPRESS
  WALK_THROUGH
  PREMIUM_1
  PREMIUM_2
  PREMIUM_3
  PREMIUM_5
  PREMIUM_10
  // ---- UNOPENED_PACK専用（PSA_USのみ）。ADR-0023 ----
  PACK_VALUE
  PACK_ECONOMY
  PACK_EXPRESS
  // ---- COMIC_MAGAZINE専用（PSA_USのみ）。ADR-0023 ----
  COMIC_MODERN
  COMIC_MODERN_PLUS
  COMIC_VINTAGE
  COMIC_VINTAGE_PLUS
  COMIC_HIGH_VALUE
  COMIC_EXPRESS
  COMIC_SUPER_EXPRESS
  COMIC_WALK_THROUGH
  // ---- 非TRADING_CARD申込のプレースホルダー値。実体はcustomServiceLevelId参照。ADR-0025 ----
  CUSTOM
}

enum ReturnMethod {
  STORE_PICKUP
  SHIPPING
}

// 鑑定提出先（料金体系が異なる）
enum ServiceRegion {
  PSA_JP
  PSA_US
}

// 鑑定対象アイテム種別（PSA_USのみ複数。PSA_JPは常にTRADING_CARD）。ADR-0023
// AUTOGRAPHはApplication/Cardのitemtype値としては使わない（申込単位の入力欄選択は常に
// TRADING_CARD/UNOPENED_PACK/COMIC_MAGAZINEの3値の固定配列で行うため混入しない）。
// PricingSetting/ShippingInsuranceRateの代理入力料金・事務手数料・送料保険料を、オートグラフ
// （デュアルサービス）専用に設定できるようにするための追加。ADR-0043
enum ItemType {
  TRADING_CARD
  UNOPENED_PACK
  COMIC_MAGAZINE // コミックとマガジンは1区分に統合
  AUTOGRAPH
}

// 動的サービスタイア（管理画面でCRUD可能）のカテゴリ。ADR-0025
// TRADING_CARDはADR-0026で追加（既存ServicePriceの固定enum方式から移行。ServicePrice自体は既存データ保持のため残置）
enum CustomServiceCategory {
  TRADING_CARD
  UNOPENED_PACK
  COMIC_MAGAZINE
  AUTOGRAPH
}

// 申込の入力経路（手数料の有無を分岐）
enum ApplicationSource {
  CUSTOMER // 顧客自身が入力（手数料なし）
  STORE // 店舗（当社）が代理入力（手数料あり）
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum UpchargeStatus {
  PENDING
  PAID
  FAILED
  WAIVED
}

enum NotificationType {
  EMAIL
  SYSTEM
}

enum InquiryStatus {
  UNREAD
  READ
  REPLIED
}

enum InquiryMessageSender {
  CUSTOMER
  STAFF
}

enum SubmissionBookingMethod {
  STORE_DROP_OFF
  SHIPPING
}

enum SubmissionBookingStatus {
  BOOKED
  CANCELLED
}

// ===== USERS (管理者・スタッフ・経理) =====

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String
  passwordHash     String
  role             UserRole @default(STAFF)
  twoFactorSecret  String?
  twoFactorEnabled Boolean  @default(false)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  operationLogs OperationLog[]
  inquiryMessages InquiryMessage[]

  @@map("users")
}

// ===== CUSTOMERS (顧客) =====

model Customer {
  id                  String    @id @default(cuid())
  memberNo            String?   @unique // 会員番号（登録時に自動発行）
  // 個人情報は暗号化して保存
  nameEncrypted       String // 表示用フルネーム（姓 名）。下記分割項目から自動生成
  nameKanaEncrypted   String // 表示用（ローマ字フルネーム）。下記分割項目から自動生成
  // 氏名（姓・名 / ローマ字 姓・名）
  lastNameEncrypted        String?
  firstNameEncrypted       String?
  lastNameRomanEncrypted   String?
  firstNameRomanEncrypted  String?
  email               String    @unique
  phoneEncrypted      String
  postalCode          String
  prefectureEncrypted String
  addressEncrypted    String
  address2Encrypted   String?
  passwordHash        String
  stripeCustomerId    String?   @unique
  emailVerified       DateTime?
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  applications  Application[]
  payments      Payment[]
  upcharges     Upcharge[]
  agreements    Agreement[]
  notifications Notification[]
  sessions      CustomerSession[]
  cards         Card[]
  addresses     CustomerAddress[]
  submissionBookings SubmissionBooking[]
  subscriptions Subscription[]
  centeringMeasurements CenteringMeasurement[]
  inquiries     Inquiry[]

  @@map("customers")
}

// 顧客の住所帳（返送先の複数登録）
model CustomerAddress {
  id                  String   @id @default(cuid())
  customerId          String
  nameEncrypted           String
  lastNameEncrypted       String?
  firstNameEncrypted      String?
  lastNameRomanEncrypted  String?
  firstNameRomanEncrypted String?
  postalCode              String
  prefectureEncrypted     String
  addressEncrypted        String
  address2Encrypted       String?
  phoneEncrypted          String?
  isDefault               Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_addresses")
}

// 新規登録のメール認証（メール入力→確認リンク→登録）
model EmailVerification {
  id         String    @id @default(cuid())
  email      String
  token      String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email])
  @@map("email_verifications")
}

// パスワード再設定（メール入力→再設定リンク→新パスワード）
model PasswordReset {
  id         String    @id @default(cuid())
  email      String
  token      String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email])
  @@map("password_resets")
}

// 継続課金（汎用サブスク。現状はセンタリング測定ツール用）。詳細: docs/CENTERING_TOOL.md / ADR-0012
enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  UNPAID
}

model Subscription {
  id                   String             @id @default(cuid())
  customerId           String
  stripeSubscriptionId String             @unique
  stripePriceId        String
  status               SubscriptionStatus
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("subscriptions")
}

// 測定手段（ライト=手動 / AI=自動検出）。ADR-0013
enum CenteringMethod {
  MANUAL
  AI
}

// センタリング測定結果（数値のみ。撮影画像は保存しない＝ADR-0012）
model CenteringMeasurement {
  id             String          @id @default(cuid())
  customerId     String
  cardId         String? // 任意で登録カードに紐付け（relationは持たない＝疎結合）
  method         CenteringMethod @default(MANUAL)
  frontLR        Float // フロント左右（大きい側%。例 58 = 58/42）
  frontTB        Float // フロント上下（大きい側%）
  backLR         Float? // バック左右（撮影は任意）
  backTB         Float? // バック上下
  estimatedGrade String? // 参考上限グレード（"10"〜"5" / null）
  note           String?
  // ①補正テレメトリ（画像は保存しない＝座標のみ）。AI提案の四隅と確定四隅を記録し、
  // AIの検出誤差・系統的ズレの分析→CV調整に使う。ADR-0013 / CENTERING_TOOL.md §学習ロードマップ。
  // 形: { front: { proposed: {outer,inner}|null, final: {outer,inner} }|null, back: 同 }
  detectionSample Json?
  createdAt      DateTime        @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("centering_measurements")
}

model CustomerSession {
  id           String   @id @default(cuid())
  customerId   String
  sessionToken String   @unique
  expires      DateTime
  createdAt    DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_sessions")
}

// ===== APPLICATIONS (申込) =====

model Application {
  id             String            @id @default(cuid())
  applicationNo  String            @unique // 表示用申込番号 APP-YYYYMMDD-XXXX
  customerId     String
  serviceLevel   ServiceLevel // 非TRADING_CARDの場合は"CUSTOM"（実体はcustomServiceLevelId参照）。ADR-0025
  region         ServiceRegion     @default(PSA_JP) // 提出先（PSA日本 / PSA US）
  itemType       ItemType          @default(TRADING_CARD) // 鑑定対象アイテム種別（PSA_USのみ複数）。ADR-0023
  // 非TRADING_CARDアイテム種別で選択したCustomServicePrice（管理画面でCRUD可能な動的サービスタイア）。ADR-0025
  customServiceLevelId   String?
  customServiceLevelName String? // スナップショット（タイア削除・改名後も過去申込の表示を保つ）
  source         ApplicationSource @default(CUSTOMER) // 顧客入力 / 当社(店舗)入力
  returnMethod   ReturnMethod
  // 返送先住所（暗号化JSON）。null の場合は顧客の登録住所を使用
  shippingAddressEncrypted String?
  // 配送先電話番号（暗号化・申込ごとに入力）
  shippingPhoneEncrypted   String?
  // 代理申込時に顧客が選択した保存カード
  savedPaymentMethodId String?
  // 下書き保存中の入力内容（カード配列・返送先選択など）。確定時にクリア
  draftData      Json?
  status         ApplicationStatus @default(DRAFT)
  // 代理入力(STORE)の先払い: 概算(枚数×鑑定料+税)を先に決済した額。段階4の差額計算用。ADR-0020
  prepaidAmount      Float   @default(0)
  // 代理入力(STORE)の先払い時に顧客が申告した申込総数（当社の総量把握のための参考値。料金計算には使わない）。ADR-0037
  estimatedCardCount Int?
  // 代理入力(STORE)の先払い時に顧客が申告した代理入力数（同一カードは1件、料金計算の基準）。一覧表示用。ADR-0038
  agencyQuantity     Int?
  // 先払い概算のサービスレベル別内訳（複数レベル同時申込に対応。例: [{serviceLevel,quantity}]）。ADR-0024
  estimatedServiceLevels Json?
  totalAmount    Float             @default(0) // 常に円。PSA USは鑑定料をJPY換算してから合算。ADR-0022/0031
  psaFeeTotal    Float             @default(0) // 表示用の鑑定料（JP=円 / US=USD、換算前の生値）。ADR-0031
  agencyFeeTotal Int               @default(0)
  handlingFee    Int               @default(0) // 事務手数料（合計）。ADR-0015
  shippingFee    Int               @default(0)
  insuranceFee   Int               @default(0)
  discountAmount Int               @default(0) // キャンペーン割引（合計）。ADR-0016
  campaignName   String? // 適用キャンペーン名（記録用）
  autographFeeTotal Float          @default(0) // 常に0（デュアルサービスは加算せず置換のため）。ADR-0029
  // PSA US決済時に使用した実効為替レート（USD→JPY、マージン込み）のスナップショット。PSA_JPはnull。ADR-0031
  exchangeRateUsed Float?
  taxAmount      Float             @default(0)
  notes          String?
  // PSA提出グループ（申込単位）。1サブミッションIDに複数申込を紐づける。ADR-0021
  psaSubmissionGroupId String?
  submittedAt    DateTime?
  receivedAt     DateTime? // 当社が実物を受取完了した日時（管理画面の「受取完了」ボタンで設定）。ADR-0034
  completedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  customer  Customer   @relation(fields: [customerId], references: [id])
  cards     Card[]
  payments  Payment[]
  agreement Agreement?
  submissionBooking SubmissionBooking?
  psaSubmissionGroup PsaSubmissionGroup? @relation(fields: [psaSubmissionGroupId], references: [id])
  // カード単位（サービスレベル別）のPSA提出グループ所属。1申込が複数グループにまたがる場合に使う。ADR-0076
  groupMemberships PsaSubmissionGroupApplication[]

  @@map("applications")
}

// ===== CARDS (カード - 最重要テーブル) =====

model Card {
  id                   String    @id @default(cuid())
  customerId           String
  applicationId        String
  cardNo               String    @unique // 自社管理番号 CARD-YYYYMMDD-XXXX
  psaSubmissionGroupId String?
  psaSubmissionId      String? // PSA Submission ID
  psaOrderId           String? // PSA Order ID
  psaCertNo            String? // PSA Cert No
  psaGrade             String? // PSA Grade (10, 9, 8, ...)
  psaGradedAt          DateTime?

  // カード情報
  lineNo        Int? // 申込内の入力順（1始まり）。お客様が店頭提出時にカードへ付けるライン番号と対応。ADR-0062
  groupLineNo   Int? // PSA提出グループ全体を通した連番（1始まり）。同一顧客の同名カードは1行にまとめ、
  // 別顧客は別行にする。「PSAへ提出済として登録」実行時に確定・保存し、以降固定。ADR-0075
  tcgTitle      String // タイトル（セット名など）
  releaseYear   String? // 発行年（トレカ/パック）または発行年月の自由記述（コミック・マガジン）。ADR-0033
  cardName      String // カード名（パックはパック名、コミック・マガジンは巻数・号として使用）。ADR-0033
  cardNumber    String? // カード番号（パック・コミック/マガジンは未使用）
  rarity        String? // レアリティ（パック・コミック/マガジンは未使用）
  language      String  @default("日本語") // 自由記述。トレカ/パックは言語、コミック・マガジンは出版社として使用。ADR-0023/0033
  declaredValue Int // 申告価格。リージョン通貨・常に整数（JP=円 / US=USD、小数点以下は扱わない）。ADR-0027
  quantity      Int          @default(1)
  // カード単位のサービスレベル（代理入力の明細確定時、カードごとに異なるタイアを選べるようにするため）。
  // 自己入力はApplication.customServiceLevelIdが全カード共通のため未設定のまま。ADR-0038
  customServiceLevelId   String?
  customServiceLevelName String?

  // 料金
  psaFee    Float @default(0) // PSA鑑定料（売価）。JP=円 / US=USD（小数点以下2桁）。ADR-0022
  psaCost   Float @default(0) // PSA原価（80%）
  agencyFee Int   @default(0) // 代行手数料
  autographRequested Boolean @default(false) // オートグラフ（デュアルサービス）希望。PSA_US×TRADING_CARDのみ意味を持つ。ADR-0023
  autographFee       Float   @default(0) // 確定時点のCustomServicePrice(category=AUTOGRAPH).pricePerCardのスナップショット合計
  autographCost      Float   @default(0) // 同・原価スナップショット合計。ADR-0025
  autographCustomServiceLevelId   String? // 選択したAutographタイア（CustomServicePrice参照）
  autographCustomServiceLevelName String? // スナップショット

  // ステータス
  status        CardStatus          @default(DRAFT)
  statusHistory CardStatusHistory[]

  // 画像（S3キー）
  frontImageKey   String?
  backImageKey    String?
  damageImageKeys String[] @default([])

  // 備考
  notes         String?
  internalNotes String?

  // QRコード
  qrCodeKey String?

  // 返却
  returnedToStoreAt    DateTime?
  returnedToCustomerAt DateTime?
  returnTrackingNo     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer           Customer            @relation(fields: [customerId], references: [id])
  application        Application         @relation(fields: [applicationId], references: [id])
  psaSubmissionGroup PsaSubmissionGroup? @relation(fields: [psaSubmissionGroupId], references: [id])
  upcharges          Upcharge[]

  @@map("cards")
}

model CardStatusHistory {
  id        String     @id @default(cuid())
  cardId    String
  status    CardStatus
  note      String?
  changedBy String? // userId or customerId
  changedAt DateTime   @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("card_status_histories")
}

// ===== PSA SUBMISSION GROUPS (PSA提出グループ) =====

model PsaSubmissionGroup {
  id              String    @id @default(cuid())
  groupNo         String    @unique // PSG-YYYYMMDD-XXX
  region                 ServiceRegion? // 提出先（PSA日本 / PSA US）。提出時に記録。ADR-0051
  itemType               ItemType?      // アイテム種別（提出先に応じた選択）。ADR-0051
  customServiceLevelId   String? // 選択したCustomServicePrice（動的サービスタイア）
  customServiceLevelName String? // スナップショット（タイア削除・改名後も過去グループの表示を保つ）
  psaSubmissionId String? // 申込番号（Sub#）
  psaOrderId      String? // 旧: PSA Order ID（未使用・後方互換で残置）。ADR-0051
  submittedAt     DateTime?
  psaReceivedAt   DateTime? // 未使用（後方互換で残置）。PSA進捗の細かい段階はstatus（下記）の自由記述で表現する
  // グループ配下の全申込を一括で④受取可能/返送準備中・⑤受取完了/返送完了に進めた日時。
  // returnMethodにより表示ラベルが分岐（STORE_PICKUP=店頭受取可能/完了、SHIPPING=返送準備中/完了）が実体は共通。ADR-0065
  returnReadyAt   DateTime?
  returnedAt      DateTime?
  // PREPARING（提出準備中）/ SUBMITTED（発送完了）は固定。それ以降はPsaProgressStatus.nameから
  // 自由記述で選び管理画面から一括更新する（PSAの進捗ステージ変化に追従するため）。ADR-0021/0034
  status          String    @default("PREPARING")
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // カード単位（サービスレベル別）のグループ割当。新規作成グループはこちらを使う。ADR-0076でADR-0021の未使用状態から復活
  cards        Card[]
  applications Application[] // 旧: 申込単位のグループ割当（既存グループの後方互換。新規作成では使わない）。ADR-0021/0076
  applicationMemberships PsaSubmissionGroupApplication[] // 新: 1申込が複数グループ（サービスレベル別）にまたがる場合の中間テーブル。ADR-0076

  @@map("psa_submission_groups")
}

// 申込×PSA提出グループの中間テーブル。1申込のカードが複数サービスレベルに分かれ、
// 別々のPsaSubmissionGroupへ割り当てられた場合に、申込側から「どのグループに属しているか」を
// 複数持てるようにする（ステータス表示はカード単位ではなく、このグループ単位のまま維持）。ADR-0076
model PsaSubmissionGroupApplication {
  id                   String   @id @default(cuid())
  applicationId        String
  psaSubmissionGroupId String
  createdAt            DateTime @default(now())

  application        Application        @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  psaSubmissionGroup PsaSubmissionGroup @relation(fields: [psaSubmissionGroupId], references: [id], onDelete: Cascade)

  @@unique([applicationId, psaSubmissionGroupId])
  @@map("psa_submission_group_applications")
}

// 管理画面で自由に追加・編集・削除できるPSA進捗ステータス（「PSA受領済み」以降の可変ステージ名）。
// PsaSubmissionGroup.statusへ名称をそのまま代入して使う（外部キーではなく選択メニューとしての役割）。ADR-0034
model PsaProgressStatus {
  id        String   @id @default(cuid())
  name      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("psa_progress_statuses")
}

// ===== PAYMENTS (決済) =====

model Payment {
  id                    String        @id @default(cuid())
  customerId            String
  applicationId         String?
  stripePaymentIntentId String?       @unique
  stripePaymentMethodId String?
  amount                Float // JP=円 / US=USD（小数点以下2桁）。ADR-0022
  currency              String        @default("jpy")
  status                PaymentStatus @default(PENDING)
  description           String?
  receiptUrl            String?
  refundedAmount        Float         @default(0)
  failureReason         String?
  paidAt                DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  customer    Customer     @relation(fields: [customerId], references: [id])
  application Application? @relation(fields: [applicationId], references: [id])

  @@map("payments")
}

// ===== UPCHARGES =====

model Upcharge {
  id                    String         @id @default(cuid())
  cardId                String
  customerId            String
  reason                String
  psaDeclaredValue      Int? // PSA申告額（ADR-0039で入力必須項目から除外・履歴用に残置）
  psaFinalValue         Int? // PSA最終評価額（ADR-0039で入力必須項目から除外・履歴用に残置）
  upchargeAmount        Int // 追加請求額
  status                UpchargeStatus @default(PENDING)
  stripePaymentIntentId String?        @unique
  notifiedAt            DateTime?
  paidAt                DateTime?
  failedAt              DateTime?
  failureReason         String?
  notes                 String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  card     Card     @relation(fields: [cardId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])

  @@map("upcharges")
}

// ===== SERVICE PRICES (サービス料金設定) =====

// 旧トレーディングカード料金（固定enum方式）。ADR-0026でCustomServicePrice(category=TRADING_CARD)へ移行済み。
// 新規のアプリロジックからは参照されない。過去データ保持・移行元データとして残置（削除しない）。
model ServicePrice {
  id               String        @id @default(cuid())
  serviceLevel     ServiceLevel
  region           ServiceRegion @default(PSA_JP)
  itemType         ItemType      @default(TRADING_CARD) // ADR-0023
  pricePerCard     Float // 1枚あたり鑑定料 = 顧客請求額（JP=円・整数 / US=USD・小数点以下2桁）。ADR-0022
  cost             Float         @default(0) // 1枚あたり原価（JP=円 / US=USD）。0なら鑑定料×80%で代替
  maxDeclaredValue Float? // 申告価格の上限。リージョン通貨・常に整数（表示はformatMoneyInt経由）。ADR-0025/0027
  isActive         Boolean       @default(true)
  updatedAt        DateTime      @updatedAt
  updatedBy        String?

  @@unique([serviceLevel, region, itemType])
  @@map("service_prices")
}

// 動的サービスタイア（管理画面で自由に追加・編集・削除可能）。トレーディングカード/未開封パック/コミック・マガジン/
// オートグラフの名称・価格・原価・申告上限を一元管理する。ADR-0025 / ADR-0026（TRADING_CARD追加）
model CustomServicePrice {
  id               String                @id @default(cuid())
  category         CustomServiceCategory
  region           ServiceRegion         @default(PSA_US)
  name             String // 表示名（自由入力）
  pricePerCard     Float // 1枚あたり価格（USD・小数点以下2桁）。Autographはカード単位の追加料金
  cost             Float                 @default(0) // 原価（USD・小数点以下2桁）。0なら鑑定料×80%で代替
  maxDeclaredValue Int? // 申告価格の上限。リージョン通貨・常に整数（JP=円 / US=USD）。nullは上限なし。ADR-0027
  isActive         Boolean               @default(true)
  sortOrder        Int                   @default(0)
  updatedAt        DateTime              @updatedAt
  updatedBy        String?

  @@index([category, region])
  @@map("custom_service_prices")
}

// 料金の一律設定（リージョン×アイテム種別別。id は既存分は "PSA_JP"/"PSA_US"、新規分は "{region}_{itemType}"）。
// 代理入力料金・事務手数料。ADR-0015 / ADR-0023（itemType軸を追加）
model PricingSetting {
  id             String        @id
  region         ServiceRegion @default(PSA_JP)
  itemType       ItemType      @default(TRADING_CARD)
  handlingFee    Int           @default(0) // 事務手数料。常に円・1申込（サービスレベル選択）につき定額。ADR-0025/0030
  proxyFee       Int           @default(0) // 代理入力料金（常に円/枚・一律）。代理入力(STORE)時のみ。ADR-0025
  freeShipInsQty Int           @default(0) // この枚数以上で送料・保険を無料(0円)化。0=無効。ADR-0017
  updatedAt      DateTime      @updatedAt
  updatedBy      String?

  // @@unique は付けない: 既存2行(id="PSA_JP"/"PSA_US")はdb push時にregion/itemTypeが
  // 一旦同一デフォルト値になり、ユニーク制約作成がP2002で失敗するため（ADR-0023 追記）。
  // 一意性はアプリ側（findFirst + create/update）で担保する。
  @@index([region, itemType])
  @@map("pricing_settings")
}

// USD→JPY為替レート（PSA US決済のJPY一本化用）。1行のみ運用（id="default"固定）。ADR-0031
model ExchangeRate {
  id            String   @id
  usdJpyRate    Float // 実勢レート（例: 155.00 = $1あたりの円）
  marginPercent Float    @default(0) // 上乗せ%。実効レート = usdJpyRate × (1 + marginPercent/100)
  updatedAt     DateTime @updatedAt
  updatedBy     String?

  @@map("exchange_rates")
}

// 店舗情報（郵送先住所等）。管理画面で編集可能。1行のみ運用（id="default"固定）。ADR-0035
model StoreSettings {
  id         String   @id
  postalCode String   @default("")
  address    String   @default("")
  storeName  String   @default("") // 例: "トレカビンクス池袋店　PSA鑑定"
  phone      String   @default("")
  // センタリング測定ツールの精度・操作性が実用に足りないため、開発が整うまで顧客画面から一時的に隠すスイッチ。ADR-0070
  centeringToolEnabled Boolean @default(true)
  updatedAt  DateTime @updatedAt
  updatedBy  String?

  @@map("store_settings")
}

// メール文面テンプレート（管理画面で編集。{{var}} を差込）。ADR-0018
model MailTemplate {
  id        String   @id @default(cuid())
  key       String   @unique // application_received / store_input_completed / grade_available / return_completed / upcharge
  name      String
  subject   String
  bodyHtml  String
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("mail_templates")
}

// カード名称マスタ（管理が手入力で蓄積。サブミッション時に検索・サジェスト）。ADR-0019
model CardNameMaster {
  id         String   @id @default(cuid())
  tcgTitle   String? // タイトル/セット名
  cardName   String
  cardNumber String?
  rarity     String?
  language   String   @default("日本語") // 自由記述（旧CardLanguage enumから変更）。ADR-0023
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([cardName])
  @@map("card_name_masters")
}

// 新規獲得キャンペーン割引（鑑定料以外・期間自動適用）。ADR-0016
enum CampaignDiscountType {
  PERCENT
  FIXED
}

model Campaign {
  id              String               @id @default(cuid())
  name            String
  discountType    CampaignDiscountType
  value           Int // PERCENT: 0-100 / FIXED: 金額
  region          ServiceRegion? // null=全リージョン
  newCustomerOnly Boolean              @default(false)
  startAt         DateTime
  endAt           DateTime
  isActive        Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@map("campaigns")
}

// 送料・保険 合算マトリクス（申告価格合計帯 × 枚数帯 → 金額）。PSA日本向け。ADR-0015 / PRICING.md
model ShippingInsuranceRate {
  id               String        @id @default(cuid())
  region           ServiceRegion @default(PSA_JP)
  itemType         ItemType      @default(TRADING_CARD) // ADR-0023
  minValue         Int // 申告価格合計の下限（円）
  maxValue         Int? // 上限（null=上限なし）
  qtyMin           Int // 枚数下限（例 1 / 9 / 26）
  qtyMax           Int? // 枚数上限（null=上限なし）
  fee              Int // セル金額（円）。26+帯では基準額（=9-25帯）
  perCardSurcharge Int           @default(0) // 26+帯の加算単価（円/枚）。通常帯は0
  sortOrder        Int           @default(0)
  isActive         Boolean       @default(true)
  updatedAt        DateTime      @updatedAt
  updatedBy        String?

  @@index([region, itemType])
  @@map("shipping_insurance_rates")
}

// ===== SHIPPING RULES (送料設定) =====

model ShippingRule {
  id           String       @id @default(cuid())
  returnMethod ReturnMethod
  itemType     ItemType     @default(TRADING_CARD) // ADR-0023
  name         String
  fee          Int // 送料（円）
  minAmount    Int          @default(0) // 最低申込金額
  maxAmount    Int? // 上限（nullなら無制限）
  isActive     Boolean      @default(true)
  sortOrder    Int          @default(0)
  updatedAt    DateTime     @updatedAt
  updatedBy    String?

  @@map("shipping_rules")
}

// ===== INSURANCE RULES (保険料設定) =====

model InsuranceRule {
  id        String   @id @default(cuid())
  itemType  ItemType @default(TRADING_CARD) // ADR-0023
  minValue  Int // 最低申告額
  maxValue  Int? // 上限（nullなら無制限）
  fee       Int // 保険料（円）
  feeRate   Float? // 料率（%）。feeとfeeRateどちらか
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("insurance_rules")
}

// ===== AGREEMENTS (電子同意書) =====

model Agreement {
  id            String   @id @default(cuid())
  customerId    String
  applicationId String   @unique
  agreedAt      DateTime @default(now())
  ipAddress     String
  userAgent     String?
  agreementText String // 同意内容スナップショット
  version       String // 同意書バージョン

  customer    Customer    @relation(fields: [customerId], references: [id])
  application Application @relation(fields: [applicationId], references: [id])

  @@map("agreements")
}

// ===== NOTIFICATIONS (お知らせ・通知) =====

model Notification {
  id         String           @id @default(cuid())
  customerId String? // nullなら全顧客向け
  type       NotificationType @default(SYSTEM)
  title      String
  body       String
  isPublished Boolean       @default(true)
  showOnMypage Boolean       @default(true)
  isRead     Boolean          @default(false)
  sentAt     DateTime?
  createdAt  DateTime         @default(now())

  customer Customer? @relation(fields: [customerId], references: [id])

  @@map("notifications")
}

// ===== ADMIN NAV ITEMS (管理画面サイドバーの表示名・並び順) =====

// idはhrefベースの固定キー（src/lib/admin-nav-defaults.tsのADMIN_NAV_DEFAULTS参照）。
// href・アイコンはコード側固定、label・sortOrderのみ管理画面(設定)から編集できる。ADR-0059
model AdminNavItem {
  id        String   @id
  label     String
  sortOrder Int      @default(0)
  updatedAt DateTime @updatedAt

  @@map("admin_nav_items")
}

// ===== LEGAL DOCUMENTS (利用規約・個人情報保護方針・カスタマーハラスメントポリシー等) =====

// idはスラッグ運用（既存3件は"terms"/"privacy"/"harassment_policy"固定、管理画面からの新規作成分は
// 入力されたスラッグをそのまま使う）。管理画面から追加・編集・削除できる。ADR-0057/0058
model LegalDocument {
  id            String     @id
  title         String // ページ見出し・ブラウザタブ用の正式名称（長くなりがち）
  footerLabel   String? // フッター表示用の短い表記。未設定ならtitleを使う。ADR-0060
  body          String // 簡易Markdown（#/##/### 見出し、* 箇条書き、**太字**、---区切り）。src/lib/legal-markdown.tsxで描画
  establishedAt DateTime // 制定日
  revisedAt     DateTime[] @default([]) // 改訂日（複数回分を配列で保持。本文の差分は保持しない）。ADR-0058
  showInFooter  Boolean    @default(true) // フッターへのリンク表示ON/OFF。ADR-0058
  updatedAt     DateTime   @updatedAt
  updatedBy     String? // 編集した管理者・スタッフのuserId

  @@map("legal_documents")
}

// ===== INQUIRIES (お問い合わせ) =====

model Inquiry {
  id         String        @id @default(cuid())
  customerId String
  subject    String
  body       String
  status     InquiryStatus @default(UNREAD)
  replyText  String?
  repliedAt  DateTime?
  repliedBy  String? // 対応した管理者・スタッフのuserId
  resolved   Boolean       @default(false) // 終了フラグ。管理者・顧客どちらからも設定可。ADR-0074
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  messages InquiryMessage[]

  @@index([customerId])
  @@map("inquiries")
}

model InquiryMessage {
  id        String               @id @default(cuid())
  inquiryId String
  sender    InquiryMessageSender
  body      String
  userId    String?
  createdAt DateTime             @default(now())

  inquiry Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([inquiryId])
  @@map("inquiry_messages")
}

// ===== SUBMISSION BOOKINGS (持込・郵送予約) =====

model SubmissionBooking {
  id            String                  @id @default(cuid())
  customerId    String
  applicationId String                  @unique
  method        SubmissionBookingMethod
  scheduledAt   DateTime
  status        SubmissionBookingStatus @default(BOOKED)
  note          String?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([scheduledAt])
  @@map("submission_bookings")
}

model SubmissionCalendarDay {
  id            String   @id @default(cuid())
  date          DateTime @unique
  isClosed      Boolean  @default(false)
  isShippingDay Boolean  @default(false)
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([date])
  @@map("submission_calendar_days")
}

// ===== OPERATION LOGS (操作ログ) =====

model OperationLog {
  id         String   @id @default(cuid())
  userId     String? // 管理者・スタッフID
  customerId String? // 顧客ID
  ipAddress  String
  action     String // 操作内容
  targetType String? // 対象テーブル
  targetId   String? // 対象ID
  before     Json? // 変更前
  after      Json? // 変更後
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([customerId])
  @@index([createdAt])
  @@map("operation_logs")
}

// ===== SAVED PAYMENT METHODS (保存済み支払い方法) =====

model SavedPaymentMethod {
  id                    String   @id @default(cuid())
  customerId            String
  stripePaymentMethodId String   @unique
  brand                 String // visa, mastercard, etc.
  last4                 String
  expMonth              Int
  expYear               Int
  isDefault             Boolean  @default(false)
  createdAt             DateTime @default(now())

  @@map("saved_payment_methods")
}
